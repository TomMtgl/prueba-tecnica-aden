<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- CARRERAS -->
        <record id="career_sistemas" model="university.career">
            <field name="name">Ingeniería en Sistemas</field>
            <field name="code">ISI</field>
            <field name="duration_years">5</field>
        </record>

        <record id="career_industrial" model="university.career">
            <field name="name">Ingeniería Industrial</field>
            <field name="code">IND</field>
            <field name="duration_years">5</field>
        </record>

        <!-- PLANES DE ESTUDIO -->
        <record id="plan_isi_2024" model="university.study_plan">
            <field name="name">Plan ISI 2024</field>
            <field name="year">2024</field>
            <field name="career_id" ref="career_sistemas"/>
        </record>

        <record id="plan_ind_2023" model="university.study_plan">
            <field name="name">Plan IND 2023</field>
            <field name="year">2023</field>
            <field name="career_id" ref="career_industrial"/>
        </record>

        <!-- PROFESORES -->
        <record id="teacher_garcia" model="university.teacher">
            <field name="name">Juan</field>
            <field name="last_name">García</field>
            <field name="complete_name">Juan García</field>
            <field name="employee_id">PROF001</field>
            <field name="email">juan.garcia@univ.edu</field>
            <field name="phone">444111</field>
            <field name="specialization">Matemática y Lógica</field>
        </record>

        <record id="teacher_rodriguez" model="university.teacher">
            <field name="name">María</field>
            <field name="last_name">Rodríguez</field>
            <field name="complete_name">María Rodríguez</field>
            <field name="employee_id">PROF002</field>
            <field name="email">m.rod@univ.edu</field>
            <field name="phone">444222</field>
            <field name="specialization">Física Aplicada</field>
        </record>

        <record id="teacher_lopez" model="university.teacher">
            <field name="name">Carlos</field>
            <field name="last_name">López</field>
            <field name="complete_name">Carlos López</field>
            <field name="employee_id">PROF003</field>
            <field name="email">c.lopez@univ.edu</field>
            <field name="phone">444333</field>
            <field name="specialization">Programación y Algoritmos</field>
        </record>

        <!-- ASIGNATURAS -->
        <record id="subject_analisis" model="university.subject">
            <field name="name">Análisis Matemático 1</field>
            <field name="code">MAT101</field>
            <field name="study_plan_id" ref="plan_isi_2024"/>
            <field name="year">1</field>
            <field name="semester">1</field>
            <field name="qualified_teacher_ids" eval="[(4, ref('teacher_garcia')), (4, ref('teacher_rodriguez'))]"/>
        </record>

        <record id="subject_programacion" model="university.subject">
            <field name="name">Programación I</field>
            <field name="code">PROG101</field>
            <field name="study_plan_id" ref="plan_isi_2024"/>
            <field name="year">1</field>
            <field name="semester">1</field>
            <field name="qualified_teacher_ids" eval="[(4, ref('teacher_lopez'))]"/>
        </record>

        <record id="subject_fisica" model="university.subject">
            <field name="name">Física I</field>
            <field name="code">FIS101</field>
            <field name="study_plan_id" ref="plan_ind_2023"/>
            <field name="year">1</field>
            <field name="semester">1</field>
            <field name="qualified_teacher_ids" eval="[(4, ref('teacher_rodriguez'))]"/>
        </record>

        <!-- CURSOS (COMISIONES) -->
        <record id="course_analisis_a" model="university.course">
            <field name="name">Análisis - Comisión A</field>
            <field name="subject_id" ref="subject_analisis"/>
            <field name="teacher_id" ref="teacher_garcia"/>
            <field name="capacity">30</field>
        </record>

        <record id="course_prog_a" model="university.course">
            <field name="name">Prog I - Comisión Nocturna</field>
            <field name="subject_id" ref="subject_programacion"/>
            <field name="teacher_id" ref="teacher_lopez"/>
            <field name="capacity">20</field>
        </record>

        <!-- ESTUDIANTES -->
        <record id="student_1" model="university.student">
            <field name="name">Francisco</field>
            <field name="last_name">Martinez</field>
            <field name="complete_name">Francisco Martinez</field>
            <field name="student_id">2024001</field>
            <field name="email">f.martinez@est.edu</field>
        </record>

        <record id="student_2" model="university.student">
            <field name="name">Lucía</field>
            <field name="last_name">Fernández</field>
            <field name="complete_name">Lucía Fernández</field>
            <field name="student_id">2024002</field>
            <field name="email">l.fer@est.edu</field>
        </record>

        <record id="student_3" model="university.student">
            <field name="name">Mateo</field>
            <field name="last_name">Gómez</field>
            <field name="complete_name">Mateo Gómez</field>
            <field name="student_id">2024003</field>
            <field name="email">m.gomez@est.edu</field>
        </record>
    </data>
</odoo>
