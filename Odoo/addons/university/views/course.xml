<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista List (antes Tree) -->
    <record id="view_university_course_list" model="ir.ui.view">
        <field name="name">university.course.list</field>
        <field name="model">university.course</field>
        <field name="arch" type="xml">
            <list decoration-danger="enrolled_count >= capacity">
                <field name="name"/>
                <field name="subject_id"/>
                <field name="teacher_id"/>
                <field name="enrolled_count" string="Inscriptos"/>
                <field name="capacity" string="Cupo"/>
                <field name="enrolled_count" widget="progressbar" options="{'max_field': 'capacity'}" string="Llenado"/>
            </list>
        </field>
    </record>

    <!-- Vista Form -->
    <record id="view_university_course_form" model="ir.ui.view">
        <field name="name">university.course.form</field>
        <field name="model">university.course</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="subject_id"/>
                            <field name="teacher_id" 
                                   options="{'no_create': True}" 
                                   domain="[('qualified_subject_ids', '=', subject_id)]"
                                   placeholder="Seleccione un profesor calificado..."/>
                        </group>
                        <group>
                            <field name="capacity"/>
                            <field name="enrolled_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Inscripciones">
                            <field name="inscription_ids">
                                <list>
                                    <field name="student_id"/>
                                    <field name="enrollment_date"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción -->
    <record id="action_university_course" model="ir.actions.act_window">
        <field name="name">Cursos</field>
        <field name="res_model">university.course</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_university_course_list"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea el primer curso!
            </p>
        </field>
    </record>
</odoo>