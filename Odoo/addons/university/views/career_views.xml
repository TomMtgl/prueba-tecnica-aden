<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_career_list" model="ir.ui.view">
        <field name="name">university.career.list</field>
        <field name="model">university.career</field>
        <field name="arch" type="xml">
            <list string="Carreras">
                <field name="code"/>
                <field name="name"/>
                <field name="duration_years"/>
                <field name="student_count" string="Inscriptos"/>
            </list>
        </field>
    </record>
    
    <record id="view_career_form" model="ir.ui.view">
        <field name="name">university.career.form</field>
        <field name="model">university.career</field>
        <field name="arch" type="xml">
            <form string="Carrera">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_university_enrollment)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-users"
                                context="{'default_career_id': id}">
                            <field name="student_count" widget="statinfo" string="Inscriptos"/>
                        </button>
                    </div>
                    
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="duration_years"/>
                            <field name="active"/>
                        </group>
                    </group>
                    
                    <group string="Descripción">
                        <field name="description" nolabel="1" placeholder="Breve descripción de la carrera..."/>
                    </group>
                    
                    <notebook>
                        <page string="Planes de Estudio">
                            <field name="study_plan_ids">
                                <list> 
                                    <field name="year"/>
                                    <field name="name"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_university_career" model="ir.actions.act_window">
        <field name="name">Carreras</field>
        <field name="res_model">university.career</field>
        <field name="view_mode">list,form</field>
    </record> <record id="view_study_plan_list" model="ir.ui.view">
        <field name="name">university.study_plan.list</field>
        <field name="model">university.study_plan</field>
        <field name="arch" type="xml">
            <list string="Planes de Estudio">
                <field name="career_id"/>
                <field name="year"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    
    <record id="view_study_plan_form" model="ir.ui.view">
        <field name="name">university.study_plan.form</field>
        <field name="model">university.study_plan</field>
        <field name="arch" type="xml">
            <form string="Plan de Estudios">
                <sheet>
                    <group>
                        <group>
                            <field name="career_id"/>
                            <field name="year"/>
                        </group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                        </group>
                    </group>
                    
                    <group string="Descripción">
                        <field name="description" nolabel="1"/>
                    </group>
                    
                    <notebook>
                        <page string="Asignaturas">
                            <field name="subject_ids">
                                <list> 
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="year"/>
                                    <field name="semester"/>
                                    <field name="teacher_id"/>
                                    <field name="enrollment_count" string="Inscriptos"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_university_study_plan" model="ir.actions.act_window">
        <field name="name">Planes de Estudio</field>
        <field name="res_model">university.study_plan</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>