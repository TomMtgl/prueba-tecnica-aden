<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_teacher_list" model="ir.ui.view">
        <field name="name">university.teacher.list</field>
        <field name="model">university.teacher</field>
        <field name="arch" type="xml">
            <list string="Profesores">
                <field name="employee_id"/>
                <field name="complete_name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="subject_count" string="Asignaturas"/>
            </list>
        </field>
    </record>
    
    <record id="view_teacher_form" model="ir.ui.view">
        <field name="name">university.teacher.form</field>
        <field name="model">university.teacher</field>
        <field name="arch" type="xml">
            <form string="Profesor">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="complete_name" placeholder="Nombre del profesor" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Información Personal">
                            <field name="name"/>
                            <field name="last_name"/>
                            <field name="employee_id"/>
                            <field name="specialization"/>
                        </group>
                        
                        <group string="Información de Contacto">
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="address"/>
                        </group>
                    </group>
                    
                    <group string="Información Bancaria - Para Pagos" groups="university.group_finance">
                        <group>
                            <field name="bank_name"/>
                            <field name="bank_account"/>
                        </group>
                        <group>
                            <field name="tax_id"/>
                        </group>
                    </group>
                    
                    <group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Asignaturas">
                            <field name="subject_ids">
                                <list>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="study_plan_id"/>
                                    <field name="year"/>
                                    <field name="enrollment_count" string="Inscriptos"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notas">
                            <field name="notes" nolabel="1" placeholder="Observaciones sobre el docente..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_university_teacher" model="ir.actions.act_window">
        <field name="name">Profesores</field>
        <field name="res_model">university.teacher</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>