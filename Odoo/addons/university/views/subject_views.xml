<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_subject_list" model="ir.ui.view">
        <field name="name">university.subject.list</field>
        <field name="model">university.subject</field>
        <field name="arch" type="xml">
            <list string="Asignaturas">
                <field name="code"/>
                <field name="name"/>
                <field name="study_plan_id"/>
                <field name="year"/>
                <field name="semester"/>
                <field name="qualified_teacher_ids" widget="many2many_tags"/>
                <field name="enrollment_count" string="Inscriptos" widget="badge"/>
            </list>
        </field>
    </record>
    
    <record id="view_subject_form" model="ir.ui.view">
        <field name="name">university.subject.form</field>
        <field name="model">university.subject</field>
        <field name="arch" type="xml">
            <form string="Asignatura">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="study_plan_id"/>
                        </group>
                        <group>
                            <field name="year"/>
                            <field name="semester"/>
                            <field name="active"/>
                        </group>
                    </group>
                    
                    <group>
                        <group>
                            <field name="credits"/>
                            <field name="hours_per_week"/>
                        </group>
                        <group>
                            <field name="qualified_teacher_ids" widget="many2many_tags" placeholder="Asignar profesores..."/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Detalle de Profesores Calificados" name="qualified_teachers_list">
                            <field name="qualified_teacher_ids" readonly="1">
                                <list>
                                    <field name="complete_name"/>
                                    <field name="employee_id"/>
                                    <field name="specialization"/>
                                </list>
                            </field>
                        </page>
                        <page string="Inscripciones">
                            <field name="enrollment_ids">
                                <list>
                                    <field name="student_id"/>
                                    <field name="enrollment_date"/>
                                    <field name="state"/>
                                    <field name="final_grade"/>
                                </list>
                            </field>
                        </page>
                        <page string="Descripción" name="description">
                            <field name="description" placeholder="Objetivos de la materia..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="view_subject_search" model="ir.ui.view">
        <field name="name">university.subject.search</field>
        <field name="model">university.subject</field>
        <field name="arch" type="xml">
            <search string="Buscar Asignaturas">
                <field name="name"/>
                <field name="code"/>
                <field name="study_plan_id"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_by_plan" string="Plan de Estudios" context="{'group_by': 'study_plan_id'}"/>
                    <filter name="group_by_year" string="Año" context="{'group_by': 'year'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <record id="action_university_subject" model="ir.actions.act_window">
        <field name="name">Asignaturas</field>
        <field name="res_model">university.subject</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>