<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_student_list" model="ir.ui.view">
        <field name="name">university.student.list</field>
        <field name="model">university.student</field>
        <field name="arch" type="xml">
            <list string="Estudiantes">
                <field name="student_id"/>
                <field name="complete_name"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="enrollment_count" string="Inscripciones"/>
                <field name="enrollment_date"/>
            </list>
        </field>
    </record>
    
    <record id="view_student_form" model="ir.ui.view">
        <field name="name">university.student.form</field>
        <field name="model">university.student</field>
        <field name="arch" type="xml">
            <form string="Estudiante">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="complete_name" placeholder="Nombre del estudiante" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Información Personal">
                            <field name="name"/>
                            <field name="last_name"/>
                            <field name="student_id"/>
                            <field name="enrollment_date"/>
                        </group>
                        
                        <group string="Información de Contacto">
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="address"/>
                        </group>
                    </group>
                    
                    <group>
                        <group>
                            <field name="active"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Inscripciones" name="enrollments">
                            <field name="enrollment_ids">
                                <list string="Inscripciones">
                                    <field name="career_id"/>
                                    <field name="study_plan_id"/>
                                    <field name="subject_id"/>
                                    <field name="enrollment_date"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="view_student_search" model="ir.ui.view">
        <field name="name">university.student.search</field>
        <field name="model">university.student</field>
        <field name="arch" type="xml">
            <search string="Buscar Estudiantes">
                <field name="complete_name"/>
                <field name="student_id"/>
                <field name="email"/>
                <filter string="Activos" name="active" domain="[('active', '=', True)]"/>
                <filter string="Inactivos" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>
    
    <record id="action_university_student" model="ir.actions.act_window">
        <field name="name">Estudiantes</field>
        <field name="res_model">university.student</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear un nuevo estudiante
            </p>
        </field>
    </record>
</odoo>