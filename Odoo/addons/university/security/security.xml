<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1"> <record id="module_category_university" model="ir.module.category">
            <field name="name">Universidad</field>
            <field name="description">Gestión universitaria</field>
            <field name="sequence">10</field>
        </record>
        
        <record id="group_academic" model="res.groups">
            <field name="name">Área Académica</field>
            <field name="category_id" ref="module_category_university"/>
            <field name="comment">Acceso completo a gestión académica incluyendo inscripciones</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        
        <record id="group_finance" model="res.groups">
            <field name="name">Área de Finanzas</field>
            <field name="category_id" ref="module_category_university"/>
            <field name="comment">Acceso a información de profesores para gestión de pagos</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        
    </data>
</odoo>